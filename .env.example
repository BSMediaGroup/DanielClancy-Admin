# =====================================================
# DEVELOPER + MAINTENANCE ACCESS
# =====================================================
AUTH_ACCESS_MODE=normal|maintenance|development|beta
AUTH_ACCESS_MESSAGE="Sample lockout message"
SHOW_LOCKOUT_BANNER=false
AUTH_ACCESS_BYPASS_ENABLED=true
ADMIN_DEBUG_BYPASS_CODE=
AUTH_ACCESS_BYPASS_TTL_MINUTES=15


# =====================================================
# DANIELCLANCY ADMIN AUTH
# =====================================================
# Manual env-backed master admin accounts. Secrets must exist only in
# Cloudflare Pages Function/server-side env vars.
DC_ADMIN_EMAIL_1=mail@danielclancy.net
DC_ADMIN_SECRET_1=
DC_ADMIN_EMAIL_2=daniel@brainstream.media
DC_ADMIN_SECRET_2=
DC_AUTH_SESSION_SECRET=
DC_AUTH_COOKIE_DOMAIN=.danielclancy.net
DC_PUBLIC_SITE_ORIGIN=https://danielclancy.net
DC_ADMIN_SITE_ORIGIN=https://admin.danielclancy.net
# Cloudflare KV binding name required for production Projects/Media/Alerts CMS persistence.
DC_ADMIN_KV=

# Cloudflare Turnstile protects auth gate login/signup and OAuth start flows.
# Site key may be exposed through the /api/turnstile/config Pages Function.
# Secret key must remain server-side only.
DC_TURNSTILE_SITE_KEY=
DC_TURNSTILE_SECRET_KEY=
DC_TURNSTILE_DEV_BYPASS=false

# OAuth login methods. These do not automatically grant master admin access.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Future-safe OAuth admin allowlists after provider identifiers are verified.
DC_ADMIN_OAUTH_GITHUB_ALLOWLIST=
DC_ADMIN_OAUTH_GOOGLE_ALLOWLIST=
DC_ADMIN_OAUTH_TWITTER_ALLOWLIST=


# =====================================================
# CREATOR: DANIEL
# =====================================================

# -----------------------------------------------------
# RUMBLE – LIVESTREAM METADATA (READ / DISCOVERY)
# -----------------------------------------------------
# Used for:
# - detecting if the stream is live
# - retrieving livestream metadata
# - discovering chat room IDs
#
# NOTE:
# - This is a READ-ONLY capability
# - One key per Rumble USER account
# - Does NOT allow chat posting
# -----------------------------------------------------
RUMBLE_LIVESTREAM_KEY_DANIEL=


# -----------------------------------------------------
# RUMBLE – AUTH COOKIES (AUTHORITATIVE)
# -----------------------------------------------------

RUMBLE_BOT_SESSION_COOKIE_DANIEL=
RUMBLE_U_S=
RUMBLE_A_S=
RUMBLE_CF_CLEARANCE=
RUMBLE_CF_BM=


# -----------------------------------------------------
# YOUTUBE – DATA + CHAT (BOT USER CONTEXT)
# -----------------------------------------------------
# Used for:
# - livestream detection
# - reading chat
# - future uploads if enabled
# -----------------------------------------------------
YOUTUBE_API_KEY_DANIEL=


# -----------------------------------------------------
# X (TWITTER) 
# -----------------------------------------------------
#
# NOTE:
# - OAuth 2.0 user context
# - Bearer token NOT required
# -----------------------------------------------------
X_CLIENT_ID_DANIEL=
X_CLIENT_SECRET_DANIEL=
X_USER_ACCESS_TOKEN_DANIEL=
X_USER_ACCESS_SECRET_DANIEL=

X_APP_ID=
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=

X_ADMIN_HANDLE=@DanielClancy

# =====================================================
# PUSHOVER NOTIFICATION SETTINGS
# =====================================================
PUSHOVER_USER_KEY=replace_with_pushover_user_key
PUSHOVER_EMAIL_ALIAS=replace_with_pushover_email_alias
PUSHOVER_API_KEY=replace_with_pushover_api_key


# Optional DanielClancy.net alert ingest bridge. Required only when
# admin.danielclancy.net or danielclancy.net posts alert events to
# POST /api/alerts/danielclancy.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Use the same value only in server/runtime sender environments. Never expose it in frontend code.
DANIELCLANCY_ALERT_INGEST_SECRET=
DANIELCLANCY_ALERT_INGEST_URL=https://api.streamsuites.app/api/alerts/danielclancy

# DanielClancy public-to-admin analytics ingest.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Use the same value only in DanielClancy-Admin and the public DanielClancy Pages Function env.
DANIELCLANCY_ANALYTICS_INGEST_SECRET=0dc889d8ec04d5225dedd3a74c02682d4f9e8675f4bdecbc0e419139e5d000568b3f0fc99c3a8612cc7804ef86d99184
DANIELCLANCY_ADMIN_ANALYTICS_INGEST_URL=https://admin.danielclancy.net/api/analytics/ingest/page-visit

# Optional public base URL for R2-backed admin-uploaded assets.
# R2 binding name for Cloudflare Pages: DC_ADMIN_ASSETS_R2
DC_ADMIN_ASSETS_PUBLIC_BASE_URL=https://cdn.danielclancy.net


# =====================================================
# CLOUDFLARE ZONE ANALYTICS
# =====================================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID_DANIELCLANCY=
CLOUDFLARE_API_TOKEN_ANALYTICS=
